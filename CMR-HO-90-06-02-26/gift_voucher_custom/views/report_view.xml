<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_loyalty_program_form_inherit" model="ir.ui.view">
        <field name="name">loyalty.program.form.inherit</field>
        <field name="model">loyalty.program</field>
        <field name="inherit_id" ref="loyalty.loyalty_program_gift_ewallet_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_print_loyalty_cards"
                        string="Print Loyalty Cards"
                        type="object"
                        class="oe_highlight"/>
            </xpath>
        </field>
    </record>
</odoo>