<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="owl.birthdayDashboard" owl="1">

        <div style="display:flex;padding-top:15vh;gap:5%">

            <!-- LEFT SIDE (ANNIVERSARY) -->
                <!--box1-->

                <div style=" margin-left:2%;border-radius:15px; background-color:#F4FBFB;width:45%; height:70vh; overflow:auto; scrollbar-width: none; -ms-overflow-style: none;padding:20px;box-shadow:0 4px 10px rgba(0,0,0,0.1);border:0.5px solid #8ebdba">
                    <h2 class="fw-bold text-center" style="text-decoration:underline"> Work Anniversaries </h2>
                    <p class="text-center" style="font-size: 15px; margin-top: 10px;">
                        Celebrate your colleagues hitting milestones!
                    </p>


                    <!-- Anniversary Cards -->
                    <t t-if="state.anniversaries.length > 0">
                        <t t-foreach="state.anniversaries" t-as="emp" t-key="emp.name">
                            <t t-if="emp.years_completed > 0">
                                <div class="m-2 p-4 text-dark" style="background-color:white">
                                    <p class="fw-bold mt-2"><b><t t-esc="emp.name"/></b> (<b><t t-esc="emp.id"/></b>)  is celebrating their <b><t t-esc="emp.years_suffix"/> Year Anniversary</b></p>
                                    <hr/>
                                </div>
                            </t>
                        </t>
                    </t>

                    <!-- No Anniversaries -->
                    <t t-if="state.anniversaries.length === 0">
                        <div class="shadow-sm m-2 p-5" style="background-color:white">
                            <h3 class="mt-3 fw-bold">No Anniversaries today</h3>
                            <p style="font-size: 14px;">Check again tomorrow!</p>
                        </div>
                    </t>
                </div>


            <!-- RIGHT SIDE (BIRTHDAY) -->

                <div  style="border-radius:15px; background-color:#F4FBFB;width:45%; height:70vh; overflow:auto; scrollbar-width: none; -ms-overflow-style: none;padding:20px;box-shadow:0 4px 10px rgba(0,0,0,0.1);border:0.5px solid #8ebdba">
                    <h2 class="fw-bold text-center" style="text-align:center;text-decoration:underline">Birthdays</h2>
                    <p class="text-center" style="font-size: 15px; margin-top: 10px;">
                        Celebrate your colleagues on their special day!
                    </p>


                    <!-- Birthday Cards -->
                    <t t-if="state.birthdays.length > 0">
                        <t t-foreach="state.birthdays" t-as="emp" t-key="emp.name">
                            <div class="m-2 p-4 text-dark" style="background-color:white">
                                <p>
                                    <b><t t-esc="emp.name"/></b> (<b><t t-esc="emp.id"/></b>) is celebrating their birthday on <b><t t-esc="emp.birthday"/></b>
                                </p>
                                <hr/>
                            </div>
                        </t>
                    </t>

                    <!-- No Birthdays -->
                    <t t-if="state.birthdays.length === 0">
                        <div class="shadow-sm m-2 p-5" style="background-color:white">
                            <h3 class="mt-3 fw-bold">No Birthday today</h3>
                            <p style="font-size: 14px;">Check again tomorrow!</p>
                        </div>
                    </t>
                </div>
            </div>


    </t>
</templates>
