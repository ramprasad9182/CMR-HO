<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="picking_form_inherit_opened_received_dasha" model="ir.ui.view">
        <field name="name">stock.form.is_opened.is_received.dasha</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='location_id']" position="after">
                <field name="is_opened" widget="boolean_toggle" invisible="picking_type_code != 'incoming'" readonly="state == 'done'"/>
                <field name="is_received" widget="boolean_toggle" invisible="picking_type_code != 'incoming'" readonly="state == 'done'"/>
            </xpath>
        </field>
    </record>


    <record id="action_stock_report" model="ir.actions.client">
        <field name="name">Stock Report</field>
        <field name="tag">stock_report_action</field>
    </record>

    <menuitem
        id="menu_stock_report"
        name="Stock Report"
        parent="sale.sale_menu_root"
        action="action_stock_report"
        sequence="46"
    />

</odoo>