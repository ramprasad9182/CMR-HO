<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_store_replenishment_tree" model="ir.ui.view">
        <field name="name">store.replenishment.tree</field>
        <field name="model">store.replenishment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="store_id"/>
                <field name="repl_type"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <record id="view_store_replenishment_form" model="ir.ui.view">
        <field name="name">store.replenishment.form</field>
        <field name="model">store.replenishment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="alert alert-success" role="alert" invisible="update_replication == False">
                    <field name="warning_message" style="white-space: pre-wrap;"/>
                </div>
                <div class="alert alert-danger" role="alert" invisible="update_replication == True">
                    <field name="warning_message" style="white-space: pre-wrap;"/>
                </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <field name="store_id" options="{'no_create': True, 'no_open': True, 'no_edit':True}"
                               readonly="1" force_save="1"/>
                        <field name="repl_type"/>
                        <field name="product_tmpl_id" options="{'no_create': True, 'no_open': True, 'no_edit':True}"
                               invisible="repl_type != 'regular'"/>
                    </group>
                    <notebook>
                        <page string="Replenishment Planning">
                            <field name="line_ids" nolabel="1">
                                <tree editable="bottom" delete="0">
                                    <field name="product_tmpl_id"
                                           options="{'no_create': True, 'no_open': True, 'no_edit':True}"
                                           invisible="parent.repl_type != 'regular'" column_invisible="1"/>
                                    <field name="price_from"/>
                                    <field name="price_to"/>
                                    <field name="min_qty"/>
                                    <field name="max_qty"/>
                                    <field name="onhand_qty" readonly="1"/>
                                    <field name="differ_qty" readonly="1"/>
                                    <field name="indent_qty"/>
                                    <field name="to_be_qty" readonly="1"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Integration">
                                                        <button name="get_stores_data" type="object" string="Get Stores" class="oe_highlight"/>
                    <group>
                        <field name="nhcl_id" readonly="1" force_save="1"/>
                        <field name="update_replication" readonly="1" force_save="1"/>
                        <field name="update_status" readonly="1" force_save="1"/>
                        <button name="send_replenishment_data_to_store" type="object" string="Create" class="oe_highlight" invisible="update_replication == True"/>
                    </group>
                            <field name="replenishment_id" nolabel="1">
                                <tree create="0" editable="bottom" delete="0" edit="0">
                                    <field name="store_id" width="40%"/>
                                    <field name="status" width="30%"/>
                                    <field name="date_replication" width="30%"/>
                                    <field name="update_status" width="30%"/>
                                    <field name="nhcl_terminal_ip"/>
                                    <field name="nhcl_port_no"/>
                                    <field name="nhcl_api_key"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


