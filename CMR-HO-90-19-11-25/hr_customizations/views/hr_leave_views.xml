<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_hr_leave_tree_inherit_emp_code" model="ir.ui.view">
        <field name="name">hr.leave.tree.emp.code</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_tree"/>
        <field name="arch" type="xml">

            <!-- Insert after employee_id -->
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="emp_code"/>
            </xpath>

        </field>
    </record>


    <record id="view_hr_leave_form_inherit_emp_code" model="ir.ui.view">
        <field name="name">hr.leave.form.emp.code</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_manager"/>
        <field name="arch" type="xml">

            <!-- Insert after employee_id -->
            <xpath expr="//field[@name='holiday_status_id']" position="before">
                <field name="emp_code"/>
            </xpath>

        </field>
    </record>


</odoo>

