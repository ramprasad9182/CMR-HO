<odoo>

    <record id="paperformat_gift" model="report.paperformat">
        <field name="name">Transfer Note Odt</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">25</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">4</field>
        <field name="margin_right">4</field>
        <field name="header_spacing">12</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_loyalty_card" model="ir.actions.report">
        <field name="name">Loyalty Card</field>
        <field name="model">loyalty.card</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">gift_voucher_custom.loyalty_card_template</field>
        <field name="report_file">gift_voucher_custom.loyalty_card_template</field>
        <field name="binding_model_id" ref="loyalty.model_loyalty_card"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Loyalty Card - %s' % (object.partner_id.name)</field>
        <field name="paperformat_id" ref="gift_voucher_custom.paperformat_gift"/>
    </record>
</odoo>
