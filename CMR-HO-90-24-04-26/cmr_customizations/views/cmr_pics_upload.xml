<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="cmr_grc_master_tree_view" model="ir.ui.view">
        <field name="name">grc.master.tree></field>
        <field name="model">grc.master</field>
        <field name="arch" type="xml">
            <tree delete="0" duplicate="0" import="0">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="cmr_grc_master_form_view" model="ir.ui.view">
        <field name="name">grc.master.form></field>
        <field name="model">grc.master</field>
        <field name="arch" type="xml">
            <form delete="0" duplicate="0">
                <sheet>
                    <group>
                        <field name="name" required="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="view_excel_qty_split_form" model="ir.ui.view">
        <field name="name">excel.qty.split.form</field>
        <field name="model">excel.qty.split</field>
        <field name="arch" type="xml">
            <form string="Excel Qty Split">
                <header>
                    <button name="action_process_from_path" type="object" string="Get Excel" class="oe_highlight"/>
<!--                    <button name="action_split_file" type="object" string="Split Excel" class="oe_highlight"/>-->
                    <button name="action_create_po_from_lines" type="object" string="Generate PO's" class="oe_highlight"/>
                    <button name="action_validate_receipts" type="object" string="Generate GRC's" class="oe_highlight"/>
                </header>
                <sheet>
                    <group>
                        <group>
<!--                            <field name="file" filename="filename"/>-->
                            <field name="filename" invisible="1"/>
                            <field name="folder_path" invisible="0"/>
                        </group>
<!--                        <group>-->
<!--                            <field name="max_qty"/>-->
<!--                        </group>-->
                    </group>

                    <notebook>
                        <page string="Split Files">
                            <field name="line_ids" nolabel="1">
                                <tree editable="bottom" delete="0" create="0">
                                    <field name="sequence"/>
                                    <field name="output_filename" string="File Name"/>
                                    <field name="is_used"/>
                                    <field name="po_id" readonly="1" force_save="1"/>
                                    <field name="output_file" widget="binary" filename="output_filename"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <record id="cmr_ob_excel_master_action" model="ir.actions.act_window">
        <field name="name">OB Master</field>
        <field name="res_model">excel.qty.split</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="cmr_grc_master_action" model="ir.actions.act_window">
        <field name="name">GRC Master</field>
        <field name="res_model">grc.master</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="cmr_grc_master"
              name="GRC Master"
              parent="stock.menu_warehouse_config"
              action="cmr_customizations.cmr_grc_master_action"
              sequence="100"/>

    <menuitem id="cmr_ob_master"
              name="OB Master"
              parent="stock.menu_warehouse_config"
              action="cmr_customizations.cmr_ob_excel_master_action"
              sequence="105"/>
</odoo>