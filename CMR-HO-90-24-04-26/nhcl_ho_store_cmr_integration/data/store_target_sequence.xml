<odoo>
    <data>

        <record id="seq_store_wise_data" model="ir.sequence">
            <field name="name">Store Wise Data</field>
            <field name="code">store.wise.data</field>
            <field name="prefix">ST/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_store_wise_report" model="ir.sequence">
            <field name="name">Store Wise Report</field>
            <field name="code">store.target.report</field>
            <field name="prefix">STR/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_store_target_replication_log" model="ir.sequence">
            <field name="name">Store Target Replication Log</field>
            <field name="code">store.wise.division.replication.log</field>
            <field name="padding">1</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">no_gap</field>
        </record>


    </data>
</odoo>
