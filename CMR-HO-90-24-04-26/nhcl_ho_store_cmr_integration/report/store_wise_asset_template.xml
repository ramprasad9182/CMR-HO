<odoo>
    <template id="store_asset_report_template">
    <t t-call="web.basic_layout">
        <t t-foreach="docs" t-as="doc">
        <t t-set="data" t-value="doc.get_asset_report_data()"/>

        <div class="page">
            <h2>Store Asset Report</h2>

            <table class="table table-bordered" style="width:100%; border-collapse: collapse;" border="1">
                <thead>
                    <tr>
                        <th>Store</th>

                        <t t-foreach="data['asset_names']" t-as="asset">
                            <th>
                                <t t-esc="asset"/>
                            </th>
                        </t>

                    </tr>
                </thead>

                <tbody>

                    <t t-foreach="data['store_data'].items()" t-as="store_row">

                        <tr>
                            <td>
                                <t t-esc="store_row[0]"/>
                            </td>

                            <t t-foreach="data['asset_names']" t-as="asset">
                                <td>
                                    <t t-esc="store_row[1].get(asset,0)"/>
                                </td>
                            </t>

                        </tr>

                    </t>

                </tbody>

            </table>
        </div>
    </t>
    </t>
</template>

