<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="nhcl_pos_cancelled_bills_report_form" model="ir.ui.view">
        <field name="name">Pos Cancelled Bills Report Form</field>
        <field name="model">nhcl.pos.cancelled.bills.report</field>
        <field name="arch" type="xml">
            <form string="POS Cancelled Bills Report" create="0">
                <h1 style="color:black;font-weight:1000;text-align:center;">POS Cancelled Bills Report</h1>
                <sheet>

                    <header>
                        <button name="action_load_data" type="object"
                                string="Load" class="btn-primary"/>
                        <button name="action_to_reset" type="object"
                                string="Reset" class="btn-secondary"/>
                        <button name="action_get_excel" type="object"
                                string="Excel" class="btn-success"/>
                        <button name="action_view_pos_cancelled_bills" type="object"
                                string="View Detailed Report" class="btn-success"/>

                    </header>
                    <group style="border: 2px solid #990099; padding: 10px;">
                        <group>
                            <field name="nhcl_store_id"
                                   string="Company"
                                   widget="many2many_checkboxes"
                                   domain="[('nhcl_active','=',True),
                                            ('nhcl_store_type','!=','ho')]"/>

                        </group>
                        <group>
                            <group>
                                <field name="from_date" required="1" widget="daterange"
                                       options="{'to_date_field': 'to_date'}"/>
                                <field name="to_date" required="1"/>
                            </group>

                        </group>
                    </group>
                    <notebook>
                        <page string="POS Order Report">
                            <group>
                                <group>
                                    <field name="total_order_quantity"/>
                                    <field name="total_amount_total"/>
                                    <field name="total_in_amount_total"/>
                                </group>
                                <group>
                                    <field name="total_discount_amount"/>
                                    <field name="total_tax_amount"/>
                                </group>
                            </group>
                            <field name="cancel_bills_report_ids" readonly="1" forsesave="1">
                                <tree create="0" delete="0" editable="bottom" limit="1000000">
                                    <field name="nhcl_company_id"/>
                                    <field name="config_id"/>
                                    <field name="nhcl_order_ref"/>
                                    <field name="nhcl_date_order"/>
<!--                                    <field name="partner_phone"/>-->
                                    <field name="nhcl_order_quantity" sum="Total Quantity"/>
                                    <field name="nhcl_discount_amount" sum="Total Discount"/>
                                    <field name="nhcl_amount_total" sum="Total Net"/>
                                    <field name="nhcl_tax_amount" sum="Total Tax"/>
                                    <field name="nhcl_in_amount_total" sum="Total Gross"/>
                                </tree>
                            </field>

                        </page>
                    </notebook>
                </sheet>

            </form>
        </field>
    </record>

    <record id="view_nhcl_pos_cancelled_bills_report_line_tree" model="ir.ui.view">
        <field name="name">nhcl.pos.cancelled.bills.report.line.tree</field>
        <field name="model">nhcl.pos.cancelled.bills.report.line</field>
        <field name="arch" type="xml">
            <tree>
                <field name="nhcl_company_id"/>
                <field name="config_id"/>
                <field name="nhcl_order_ref"/>
                <field name="nhcl_date_order"/>
<!--                <field name="partner_phone"/>-->
                <field name="nhcl_order_quantity" sum="Total Quantity"/>
                <field name="nhcl_discount_amount" sum="Total Discount"/>
                <field name="nhcl_amount_total" sum="Total Net"/>
                <field name="nhcl_tax_amount" sum="Total Tax"/>
                <field name="nhcl_in_amount_total" sum="Total Gross"/>
            </tree>
        </field>
    </record>

    <record id="view_nhcl_pos_cancelled_bills_report_line_pivot" model="ir.ui.view">
        <field name="name">nhcl.pos.cancelled.bills.report.line.pivot</field>
        <field name="model">nhcl.pos.cancelled.bills.report.line</field>
        <field name="arch" type="xml">
            <pivot string="POS Cancelled Bill Report Analysis">
                <field name="nhcl_company_id" type="row"/>
                <field name="config_id" type="row"/>
                <field name="partner_phone" type="row"/>
                <field name="nhcl_order_ref" type="row"/>
                <field name="nhcl_date_order" interval="day" type="col"/>
                <field name="nhcl_amount_total" type="measure"/>
                <field name="nhcl_in_amount_total" type="measure"/>
                <field name="nhcl_discount_amount" type="measure"/>
                <field name="nhcl_tax_amount" type="measure"/>
                <field name="nhcl_order_quantity" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="nhcl_pos_cancelled_bill_report" model="ir.actions.act_window">
        <field name="name">Cancelled Bills Summary</field>
        <field name="res_model">nhcl.pos.cancelled.bills.report</field>
        <field name="view_mode">form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <menuitem id="menu_nhcl_pos_cancelled_bill_report"
              name="Cancelled Bills Summary Report"
              parent="nhcl_ho_store_cmr_integration.reporting_store_heading"
              action="nhcl_ho_store_cmr_integration.nhcl_pos_cancelled_bill_report"
              sequence="13"/>

</odoo>