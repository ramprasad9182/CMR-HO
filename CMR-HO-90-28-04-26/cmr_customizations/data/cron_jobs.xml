<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="ir_cron_check_end_date" model="ir.cron">
            <field name="name">Advertisement Order Alert's</field>
            <field name="model_id" ref="model_purchase_order"/>
            <field name="state">code</field>
            <field name="code">model._check_end_date_for_alerts()</field>
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <record id="ir_cron_send_payment_alerts" model="ir.cron">
            <field name="name">Payment Alert's</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="state">code</field>
            <field name="code">model.alert_on_payment_terms()</field>
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <record id="ir_cron_product_margin_approval_reminder" model="ir.cron">
            <field name="name">Product Margin Approval Reminder</field>
            <field name="model_id" ref="model_product_margin_approval"/>
            <field name="state">code</field>
            <field name="code">model.create_manager_activity()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <odoo>
    <record id="ir_cron_auto_cancel_old_sale_orders" model="ir.cron">
        <field name="name">Auto Cancel Old Sale Orders</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="state">code</field>
        <field name="code">model.auto_cancel_old_sale_orders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="nextcall" eval="(DateTime.now().replace(hour=11, minute=0, second=0))"/>
        <field name="active">True</field>
    </record>
</odoo>

    </data>
</odoo>