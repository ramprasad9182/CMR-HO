<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="logistic_entry_check" model="ir.actions.server">
            <field name="name">Logistic Entry Check</field>
            <field name="model_id" ref="cmr_customizations.model_logistic_screen_data"/>
            <field name="binding_model_id" ref="cmr_customizations.model_logistic_screen_data"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
                records.logistic_entry_check()
            </field>
        </record>

        <record id="logistic_transport_check" model="ir.actions.server">
            <field name="name">Logistic Transport Check</field>
            <field name="model_id" ref="cmr_customizations.model_transport_check"/>
            <field name="binding_model_id" ref="cmr_customizations.model_transport_check"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
                records.logistic_transport_check()
            </field>
        </record>

        <record id="open_parcel_server_action" model="ir.actions.server">
            <field name="name">Open Parcel</field>
            <field name="model_id" ref="cmr_customizations.model_open_parcel"/>
            <field name="binding_model_id" ref="cmr_customizations.model_open_parcel"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
                records.open_parcel()
            </field>
        </record>

        <record id="manf_bulk_update_server_action" model="ir.actions.server">
            <field name="name">Manf Bulk Update</field>
            <field name="model_id" ref="mrp.model_mrp_production"/>
            <field name="binding_model_id" ref="mrp.model_mrp_production"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
                action = records.get_production_ids()
            </field>
        </record>
    </data>
</odoo>