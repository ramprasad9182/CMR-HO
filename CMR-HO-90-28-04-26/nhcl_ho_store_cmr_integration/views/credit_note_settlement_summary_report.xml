<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="nhcl_credit_note_settlement_summary_report_form" model="ir.ui.view">
        <field name="name">credit.note.settlement.summary.report.form</field>
        <field name="model">credit.note.settlement.summary.report</field>
        <field name="arch" type="xml">
            <form string="Credit Note Settlement Summary Report"  create="0">
                <h1 style="text-align:center;font-weight:900;color:black;">
                    Credit Note Settlement Summary Report
                </h1>
                <sheet>
                    <header>
                        <button name="action_load_data"
                                type="object"
                                string="Load"
                                class="btn-primary"/>
                        <button name="action_reset"
                                type="object"
                                string="Reset"
                                class="btn-secondary"/>
                        <button name="action_get_excel"
                                type="object"
                                string="Excel"
                                class="btn-success"/>
                        <button name="action_view_credit_note_settlement_lines" type="object"
                                string="View Detailed Report" class="btn-success"/>
                    </header>
                    <group style="border:2px solid #875A7B;
                                  padding:10px;">
                        <group>

                            <field name="nhcl_store_id"
                                   string="Company"
                                   widget="many2many_tags"
                                   domain="[('nhcl_active','=',True),
                                            ('nhcl_store_type','!=','ho')]"/>

                        </group>
                        <group>
                            <field name="from_date" required="1" widget="daterange" options="{'to_date_field':'to_date'}"/>
                            <field name="to_date" required="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Report">
                            <field name="line_ids" readonly="1">
                                <tree create="0" delete="0">
                                    <field name="nhcl_company_id"/>
                                    <field name="config_id"/>
                                    <field name="date_order"/>
<!--                                    <field name="partner_phone"/>-->
                                    <field name="base_bill_no"/>
                                    <field name="net_amount" sum="Total Net"/>
                                    <field name="discount_amount" sum="Total Discount"/>
                                    <field name="gross_amount" sum="Total Gross"/>
                                    <field name="tax_amount" sum="Total Tax"/>
                                    <field name="payment_methods"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="credit_note_settlement_summary_line_tree" model="ir.ui.view">
        <field name="name">credit.note.settlement.summary.line.tree</field>
        <field name="model">credit.note.settlement.summary.line</field>
        <field name="arch" type="xml">
            <tree>
                <field name="nhcl_company_id"/>
                <field name="config_id"/>
                <field name="date_order"/>
                <field name="partner_phone"/>
                <field name="base_bill_no"/>
                <field name="net_amount" sum="Total Net"/>
                <field name="discount_amount" sum="Total Discount"/>
                <field name="gross_amount" sum="Total Gross"/>
                <field name="tax_amount" sum="Total Tax"/>
                <field name="payment_methods"/>
            </tree>
        </field>
    </record>

    <record id="view_note_settlement_summary_line_pivot" model="ir.ui.view">
        <field name="name">credit.note.settlement.summary.line.pivot</field>
        <field name="model">credit.note.settlement.summary.line</field>
        <field name="arch" type="xml">
            <pivot string="Credit Note Settlement Summary Report Analysis">
                <field name="nhcl_company_id" type="row"/>
                <field name="config_id" type="row"/>
                <field name="base_bill_no" type="row"/>
                <field name="payment_methods" type="row"/>
                <field name="date_order" interval="day" type="col"/>
                <field name="net_amount" type="measure"/>
                <field name="discount_amount" type="measure"/>
                <field name="gross_amount" type="measure"/>
                <field name="tax_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="nhcl_credit_note_settlement_summary_report" model="ir.actions.act_window">
        <field name="name">Credit Note Settlement Summary</field>
        <field name="res_model">credit.note.settlement.summary.report</field>
        <field name="view_mode">form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <menuitem id="menu_nhcl_credit_note_settlement_summary_report"
              name="Credit Note Settlement Summary Report"
              parent="reporting_store_heading"
              action="nhcl_ho_store_cmr_integration.nhcl_credit_note_settlement_summary_report"
              sequence="12"/>

</odoo>