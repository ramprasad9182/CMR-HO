<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="nhcl_hsn_wise_tax_report_action" model="ir.actions.act_window">
        <field name="name">HSN Wise Sale Report</field>
        <field name="res_model">nhcl.hsn.tax.report</field>
        <field name="view_mode">form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <record id="nhcl_hsn_wise_tax_report_form" model="ir.ui.view">
        <field name="name">HSN Wise Tax Report</field>
        <field name="model">nhcl.hsn.tax.report</field>
        <field name="arch" type="xml">
            <form string="HSN Wise Sale Report" create="0">
                <h1 style="color:black;font-weight:1000;text-align:center;">HSN Wise Sale Report</h1>
                <sheet>
                    <header>
                        <button name="get_hsn_with_tax_wise_report" type="object"
                                string="Submit" class="btn-primary"/>
                        <button name="action_to_reset" type="object"
                                string="Reset" class="btn-secondary"/>
                        <button name="get_excel_sheet" type="object"
                                string="Excel" class="btn-success"/>
                         <button name="action_hsn_tax_report_line" type="object"
                                string="View Detailed Report" class="btn-success"/>
                    </header>
                    <group name="hsn_wise_tax" style="border: 2px solid #990099; padding: 10px;">
                        <group name="pos_hour_report_group">
                            <field name="nhcl_store_id"
                                   placeholder="Select Company" domain="[('nhcl_active', '=', True),('nhcl_store_type', '!=', 'ho')]"
                                   widget="many2many_tags"/>
                            <field name="l10n_in_hsn_code" widget="l10n_in_hsn_autocomplete"/>
                        <field name="tax_id"/>
                        </group>
                        <group name="hsn_wise_date_details">
                            <group>
                                <field name="from_date" required="1" widget="daterange"
                                       options="{'to_date_field': 'to_date'}"/>
                                <field name="to_date" required="1"/>
                            </group>

                        </group>
                    </group>
                    <notebook>
                        <page string="HSN Wise Sale Report">
                            <field name="nhcl_pos_hsn_tax_ids" readonly="1" forsesave="1">
                                <tree create="0" delete="0" editable="bottom">
                                    <field name="nhcl_store_id"/>
                                    <field name="nhcl_hsn"/>
                                    <field name="nhcl_tax"/>
                                    <field name="nhcl_order_quantity" sum="total_qty"/>
                                    <field name="nhcl_amount_total" sum="total_amount"/>
                                    <field name="nhcl_taxable_amount" sum="tax_total"/>
                                    <field name="nhcl_cgst_amount" sum="cgst_total"/>
                                    <field name="nhcl_sgst_amount" sum="sgst_total"/>
                                    <field name="nhcl_tax_amount" sum="tax_amount_total"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


     <record id="view_hsn_wise_tax_report_tree" model="ir.ui.view">
        <field name="name">nhcl.hsn.tax.report.line.tree</field>
        <field name="model">nhcl.hsn.tax.report.line</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0">
                <field name="nhcl_store_id"/>
                <field name="nhcl_hsn"/>
                <field name="nhcl_tax"/>
                <field name="nhcl_order_quantity" sum="total_qty"/>
                <field name="nhcl_amount_total" sum="net_total"/>
                <field name="nhcl_taxable_amount" sum="net_total"/>
                <field name="nhcl_tax_amount" sum="net_total"/>
                <field name="nhcl_cgst_amount" sum="net_total"/>
                <field name="nhcl_sgst_amount" sum="net_total"/>
            </tree>
        </field>
    </record>
    <record id="view_hsn_wise_tax_report_pivot" model="ir.ui.view">
        <field name="name">nhcl.hsn.tax.report.line.pivot</field>
        <field name="model">nhcl.hsn.tax.report.line</field>
        <field name="arch" type="xml">
            <pivot string="HSN Wise Tax Pivot">
                <field name="nhcl_store_id" type="row"/>
                <field name="nhcl_hsn" type="row"/>
                <field name="nhcl_tax" type="row"/>
                <field name="nhcl_order_quantity" type="measure"/>
                <field name="nhcl_amount_total" type="measure"/>
                <field name="nhcl_taxable_amount" type="measure"/>
                <field name="nhcl_tax_amount" type="measure"/>
                <field name="nhcl_cgst_amount" type="measure"/>
                <field name="nhcl_sgst_amount" type="measure"/>
            </pivot>
        </field>
    </record>
</odoo>