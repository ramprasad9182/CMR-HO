<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sequence_multi_store_audit_plan" model="ir.sequence">
        <field name="name">Plan Reference</field>
        <field name="code">stores.audit.plans.data</field>
        <field name="prefix">PLAN/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
        <field name="implementation">no_gap</field>
    </record>


    <record id="stores_aduit_view_inventory_tree" model="ir.ui.view">
        <field name="name">stores.audit.plans.tree</field>
        <field name="model">stores.audit.plans.data</field>
        <field name="arch" type="xml">
            <tree string="Lot/Serial Number Inventory" sample="1">
                <field name="create_date" string="Plan Date"/>
                <field name="plan_name" string="Plan Name"/>
                <field name="start_date" string="Activation Date"/>
                <field name="name" optional="hide"/>
                <field name="product_ids" widget="many2many_tags" optional="hide"/>
                <field name="user_id" widget="many2one_tags" string="Created by"/>
                <field name="nhcl_audit_remarks"/>
                <field
                        name="company_ids"
                        groups="base.group_multi_company"
                        optional="hide"
                />


            </tree>
        </field>
    </record>

    <record id="stores_audit_view_inventory_form" model="ir.ui.view">
        <field name="name">stores.audit.plans.form</field>
        <field name="model">stores.audit.plans.data</field>
        <field name="arch" type="xml">
            <form string="Inventory Adjustment">
                <header>
                    <button
                            name="action_create_store_audit_plans"
                            string="Audit Plan allocation for Stores"
                            type="object"
                            class="oe_highlight" invisible="plan_creation_in_stores == True"
                    />
                </header>
                <sheet>

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field
                                    name="name"
                                    placeholder="e.g. Annual inventory"
                                    readonly="1"
                            />
                        </h1>
                    </div>
                    <group>
                        <group>

                            <field name="plan_name" required="1" readonly = "plan_creation_in_stores == True"/>
                            <field name="audit_type" invisible="1"/>
                            <field
                                    name="stock_inventory_category"
                                    options="{'no_create': True}" readonly = "plan_creation_in_stores == True"
                            />

                            <field
                                    name="product_ids"
                                    context="{'default_type': 'product'}"
                                    widget="many2many_tags"
                                    options="{'no_create': True}" readonly = "plan_creation_in_stores == True"

                            />
<!--                            <field name="category_1_ids" widget="many2many_tags"/>-->
                            <field name="description_1_ids" widget="many2many_tags"/>
                            <field name="type_product" />


                            <field name="from_date_range" readonly = "plan_creation_in_stores == True"/>
                            <field
                                    name="to_date_range"
                                    required="True" readonly = "plan_creation_in_stores == True"

                            />
                            <field
                                    name="create_date"
                                    string="Created Date"

                            />
<!--                            <field-->
<!--                                    name="prefill_counted_quantity"-->
<!--                                    widget="radio"-->

<!--                            />-->
                            <field name="nhcl_audit_remarks" readonly = "plan_creation_in_stores == True"/>
                            <field name="plan_creation_in_stores" invisible="0" readonly="1"/>


                        </group>
                        <group>
                            <field name="company_ids" options="{'no_create': True}" widget="many2many_tags" readonly = "plan_creation_in_stores == True"/>


                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    <record id="action_stores_audits" model="ir.actions.act_window">
        <field name="name">Stores Audit Plans</field>
        <field name="res_model">stores.audit.plans.data</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem
            id="sub_menu_stores_audits"
            name="Audit Plan Creation for Multi Stores"
            parent="stock_inventory_count_tus.main_menu_action_inventory_root"
            action="stock_inventory_count_tus.action_stores_audits"
            sequence="3"
    />
</odoo>