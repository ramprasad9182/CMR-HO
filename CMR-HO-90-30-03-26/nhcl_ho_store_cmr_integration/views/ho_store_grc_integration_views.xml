<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_integration_receipt_screen_tree" model="ir.ui.view">
    <field name="name">integration.receipt.screen.tree</field>
    <field name="model">integration.receipt.screen</field>
    <field name="arch" type="xml">
       <tree>
            <field name="nhcl_store_id"/>
           <field name="company_domain" column_invisible="1"/>
           <field name="receipt_ids" widget="many2many_tags" domain="company_domain" options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>

       </tree>
    </field>
</record>

    <record id="view_integration_receipt_screen_form" model="ir.ui.view">
    <field name="name">integration.receipt.screen.form</field>
    <field name="model">integration.receipt.screen</field>
    <field name="arch" type="xml">
        <form>
            <group>
                 <field name="nhcl_create_status" invisible="1"/>
                <field name="nhcl_store_id" readonly="nhcl_create_status"/>
                <field name="company_domain" invisible="1"/>
                <field name="receipt_ids" widget="many2many_tags" domain="company_domain" options="{'no_create': True, 'no_open': True, 'no_edit':True}" readonly="nhcl_create_status"/>
                <button name="action_integrate_receipts" type="object" class="btn-primary" string="Integration"/>
            </group>
        </form>
    </field>
</record>
    <record id="action_nhcl_receipt_screen" model="ir.actions.act_window">
        <field name="name">GRC Integration</field>
        <field name="res_model">integration.receipt.screen</field>
        <field name="view_mode">tree,form</field>
    </record>

 <menuitem id="menu_nhcl_receipt_screen"
              name="GRC Integration"
              parent="stock.menu_stock_transfers"
              action="action_nhcl_receipt_screen"
              sequence="28"/>
</odoo>